<%- include('../partials/head.ejs') %>
<%- include('../partials/background-design.ejs') %>
<link rel="stylesheet" href="css/auth.css">
    <%- include('../partials/navigation.ejs') %>
    <form id="sign-in">
        <div class="sign-header">
            <button class="back-arrow">
            <svg enable-background="new 0 0 32 32" version="1.1" viewBox="0 0 32 32"  xml:space="preserve" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
                <path d="M24.285,11.284L16,19.571l-8.285-8.288c-0.395-0.395-1.034-0.395-1.429,0  c-0.394,0.395-0.394,1.035,0,1.43l8.999,9.002l0,0l0,0c0.394,0.395,1.034,0.395,1.428,0l8.999-9.002  c0.394-0.395,0.394-1.036,0-1.431C25.319,10.889,24.679,10.889,24.285,11.284z" id="Expand_More"/><g/><g/><g/><g/><g/><g/>
            </svg>
        </button>
        <h1 class="sign-title">Logg inn</h1>
        </div>
        <label for="username">Brukernavn:</label>
        <input class="input-sign" type="text" name="username" id="username" placeholder="Skriv inn brukernavn...">
        <label for="passwd">Passord:</label>
        <input class="input-sign" type="password" name="passwd" id="passwd" placeholder="Skriv inn Passord...">
        <button class="sign-btn" type="submit">Logg inn</button>
        <div class="error"><%= error %></div>
        <p class="sign-p">Har du ikke en bruker? Registrer deg <a class="sign-link" href="/sign-up"> her! </a></p>
    </form>

<%- include('../partials/foot.ejs') %>