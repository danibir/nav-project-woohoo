<%- include('./partials/head.ejs') %>
<%- include('./partials/background-design.ejs') %>

    <link rel="stylesheet" href="/css/findData.css">

    <%- include('./partials/navigation.ejs') %>

    <section class="findDataPage">
        <ul class="searchFilter">
            <li class="activeSort">
                <a>Alle</a>
            </li>
            <li class="">
                <a>Datasett</a>
            </li>
            <li class="">
                <a>API-er</a>
            </li>
            <li class="">
                <a>Begreper</a>
            </li>
        </ul> 

        <div class="sortingField">
            <label for="sorting">Søket ditt ga <%= rdfList.length %> treff:</label>
            <select name="sorting" class="sorting" id="sorting">
                <option value="" selected disabled hidden>Sorter</option>
                <option value="">Sist publisert</option>
                <option value="">Relevanse</option>
                <option value="">A - Å</option>
                <option value="">Å - A</option>
            </select>
        </div>

        <section class="results">
            <section class="resultLeft">
                <div class="activeFilters">
                    <button><h2>Nullstill alle filtre</h2></button>
                </div>

                <section class="chooseFilters">
                    <div class="filterBox">
                        <h2>Tema:</h2>
                        <div class="filterOption">
                            <label class="filterTitle">
                                <input type="checkbox" class="realCheckbox">
                                <span class="customCheckbox"></span>
                                <h4>Arbeid</h4>
                            </label>
                            <div>
                                <img class="downArrow" src="/img/icons/downArrow.png" alt="down arrow">                    
                            </div>
                        </div>
                        <div class="filterOption secondaryOption hidden">
                            <label class="filterTitle">
                                <input type="checkbox" class="realCheckbox">
                                <span class="customCheckbox"></span>
                                <h4>Arbeidsliv</h4>
                            </label>
                        </div>
                        <div class="filterOption secondaryOption hidden">
                            <label class="filterTitle">
                                <input type="checkbox" class="realCheckbox">
                                <span class="customCheckbox"></span>
                                <h4>Permisjonsordninger</h4>
                            </label>
                        </div>

                        <div class="filterOption">
                            <label class="filterTitle">
                                <input type="checkbox" class="realCheckbox">
                                <span class="customCheckbox"></span>
                                <h4>Familie og Barn</h4>
                            </label>
                            <div>
                                <img class="downArrow" src="/img/icons/downArrow.png" alt="down arrow">
                            </div>
                        </div>
                        <div class="filterOption secondaryOption hidden">
                            <label class="filterTitle">
                                <input type="checkbox" class="realCheckbox">
                                <span class="customCheckbox"></span>
                                <h4>Foreldre og Foresatte</h4>
                            </label>
                        </div>

                        <div class="filterOption">
                            <label class="filterTitle">
                                <input type="checkbox" class="realCheckbox">
                                <span class="customCheckbox"></span>
                                <h4>Sosiale Tjenester</h4>
                            </label>
                        </div>

                    <div>
                        <h2>EU-Tema:</h2>
                        <div class="filterOption">
                            <label class="filterTitle">
                                <input type="checkbox" class="realCheckbox">
                                <span class="customCheckbox"></span>
                                <h4>Forvaltning og offentlig sektor</h4>
                            </label>
                        </div>

                        <div class="filterOption">
                            <label class="filterTitle">
                                <input type="checkbox" class="realCheckbox">
                                <span class="customCheckbox"></span>
                                <h4>Befolkning og Samfunn</h4>
                            </label>
                        </div>

                        <div class="filterOption">
                            <label class="filterTitle">
                                <input type="checkbox" class="realCheckbox">
                                <span class="customCheckbox"></span>
                                <h4>Transport</h4>
                            </label>
                        </div>

                        <div class="filterOption">
                            <label class="filterTitle">
                                <input type="checkbox" class="realCheckbox">
                                <span class="customCheckbox"></span>
                                <h4>Økonomi og Finans</h4>
                            </label>
                        </div>

                        <div class="filterOption">
                            <label class="filterTitle">
                                <input type="checkbox" class="realCheckbox">
                                <span class="customCheckbox"></span>
                                <h4>Miljø</h4>
                            </label>
                        </div>

                        <div class="filterOption">
                            <label class="filterTitle">
                                <input type="checkbox" class="realCheckbox">
                                <span class="customCheckbox"></span>
                                <h4>Internasjonale Temaer</h4>
                            </label>
                        </div>
                    </section>
                </section>

                <section class="dataPreviews">
                    <% if (dbFail) { %>
                        <p>Mangler kobling med databasen. Prøv igjen senere.</p></p>
                    <% } else if(rdfList && rdfList.length> 0) { %>
                        <% rdfList.forEach(rdf=> { console.log(rdf)%>
                            <%- include('./partials/findDataPreview.ejs', {rdf}) %>
                        <% }); %>
                    <% } else { %>
                        <div class="noData">
                            <p>Vi har for øyeblikket ingen data å vise her</p>
                        </div>
                        
                    <% } %>
                </section>
            </section>

            <script src="/script/frontend.js"></script>

            <%- include('./partials/foot.ejs') %>
        </section>