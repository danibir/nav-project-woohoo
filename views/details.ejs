<%- include('./partials/head.ejs') %>
<%- include('./partials/background-design.ejs') %>
<%- include('./partials/navigation.ejs') %>
    
<section class="full-page detailsPage datasetPage">
    <link rel="stylesheet" href="/css/dataset.css">

    <section class="datasetNavbar">
        <a href="/oversikt/<%= rdfdata.title.object.nb %>">Oversikt</a>
        <a class="active" href="/detaljer/<%= rdfdata.title.object.nb %>">Detaljer</a>
    </section>

    <h1><%= rdfdata.title.object.nb %></h1>

    <div class="topInfo">
        <div class="detailBox">
            <h2>Om Datasettet</h2>

                <div class="topInfoSection">
                    <div class="detailBoxInfo">
                        <h3>Publisert:</h3>
                        <p><%= rdfdata.issued.object %></p>
                    </div>
                    <div class="detailBoxInfo">
                        <h3>Sist Oppdatert:</h3>
                        <p><%= rdfdata.modified.object %></p>
                    </div>            
                </div>

                <div class="topInfoSection">
                    <div class="detailBoxInfo">
                        <h3>URI:</h3>
                        <% if(rdfdata.primaryTopic) { %>
                                <a href="<%= rdfdata.primaryTopic.object %>"><%= rdfdata.primaryTopic.object %></a>
                        <% } else { %>
                                <p class="unavailable">Ikke oppgitt</p>
                        <% } %>
                    </div>
                    <div class="detailBoxInfo">
                        <h3>Landingsside:</h3>
                        <% if(rdfdata.landingPage) { %>
                                <a href="<%= rdfdata.landingPage.object %>"><%= rdfdata.landingPage.object %></a>
                        <% } else { %>
                                <p class="unavailable">Ikke oppgitt</p>
                        <% } %>
                    </div>            
                </div>
            </div>
        </div>        
    </div>

    <div class="midInfo">
        <div class="detailBox">
            <h2>Tema</h2>
            <div class="dataTags">
                <% entry.tags.forEach(tag => { %>
                    <div class="dataTag">
                        <%= tag %> 
                    </div>
                <% }); %>
            </div>
        </div>

        <div class="detailBox">
            <h2>Kontaktinformasjon</h2>
            <div class="detailBoxInfo">
                <h3>Kontaktpunkt:</h3>
                <% if(rdfdata.fn) { %>
                        <p><%= rdfdata.fn.object.nb %></p>
                <% } else { %>
                        <p class="unavailable">Ikke oppgitt</p>
                <% } %>
            </div>
            <div class="detailBoxInfo">
                <h3>E-post:</h3>
                <% if(rdfdata.hasEmail) { %>
                        <p><%= rdfdata.hasEmail.object %></p>
                <% } else { %>
                        <p class="unavailable">Ikke oppgitt</p>
                <% } %>
            </div>
        </div>
    </div>

    <div class="bottomInfo">
        <div class="detailBox">
            <h2>Distrubisjoner</h2>
            <% if(rdfdata.dataset) { %>
                <div class="distributions">
                    <% rdfdata.dataset.object.forEach(dataset => { %>
                        <div class="distr">
                            <a href="<%= dataset %>"><%= dataset %></a>
                        </div>
                    <% }); %>                
                </div>
            <% } %>
        </div>        
    </div>


</section>

<%- include('./partials/foot.ejs') %>