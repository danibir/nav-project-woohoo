<% if (rdf.title.object.nb) { %>

    <section class="dataPreview" data-tema="<%= Array.isArray(item) ? item.join(',') : item %>">
        <a href="/info/<%= rdf.title.object.nb[0] %>">
            <div class="dataPreviewInfo">
                <div class="dataPreTitle">
                    <h2>
                        <%= rdf.title.object.nb %>
                    </h2>
                </div>
                <div class="dataPreInfo">
                    <p>
                        <%= rdf.description.object.nb %>
                    </p>
                </div>
                <div class="dataPreTags">
                    <% for(tag of item) { %>
                        <div class="dataPreTag">
                            <%= tag %>
                        </div>
                        <% } %>
                </div>
            </div>
        </a>
    </section>

    <% } %>